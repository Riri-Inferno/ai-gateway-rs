# ゲートウェイ自身のバインド先
GATEWAY_BIND=0.0.0.0:8080

# このゲートウェイを叩く側に配るAPIキー（カンマ区切りで複数可）
GATEWAY_API_KEYS=changeme

# 上流プロバイダのAPIキー
GOOGLE_AI_STUDIO_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Vertex AI (GCP)
# プロジェクトIDが設定されていれば登録される。認証は ADC (Application Default Credentials) 一本化。
#  - ローカル `cargo run`        : `gcloud auth application-default login` で発行された authorized_user JSON を gcp_auth が自動検出
#  - docker compose             : Service Account 鍵 (service_account 型 JSON) を VERTEX_SA_JSON_PATH で指定（compose 側でマウント）
#  - k3s 本番                   : WIF JSON をマウントして GOOGLE_APPLICATION_CREDENTIALS でパス指定
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
# docker compose 利用時のみ必要。ホスト側のSA鍵JSONへの絶対パス。
VERTEX_SA_JSON_PATH=

# ログレベル
RUST_LOG=info,server=debug,presentation=debug
