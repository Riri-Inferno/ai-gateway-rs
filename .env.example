# ゲートウェイ自身のバインド先
GATEWAY_BIND=0.0.0.0:8080

# このゲートウェイを叩く側に配るAPIキー（カンマ区切りで複数可）
GATEWAY_API_KEYS=changeme

# 上流プロバイダのAPIキー
GOOGLE_AI_STUDIO_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Vertex AI (GCP) ─ ADC認証なのでAPIキーは不要。プロジェクトIDだけ設定すれば登録される。
# 認証情報は `gcloud auth application-default login` で発行するか、
# WIF JSON をマウントして GOOGLE_APPLICATION_CREDENTIALS でパス指定する。
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/etc/gcp/wif.json

# ログレベル
RUST_LOG=info,server=debug,presentation=debug
